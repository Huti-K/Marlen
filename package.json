{
  "name": "trailin",
  "private": true,
  "version": "0.1.0",
  "description": "Local-first AI email agent (pi + Pipedream Connect MCP) with a Fastify API and a Vite/React/shadcn web UI",
  "scripts": {
    "dev": "pnpm --parallel --filter @trailin/server --filter @trailin/web dev",
    "dev:server": "pnpm --filter @trailin/server dev",
    "dev:web": "pnpm --filter @trailin/web dev",
    "demo": "TRAILIN_DEMO=1 pnpm --filter @trailin/server dev",
    "build": "pnpm -r build",
    "start": "pnpm --filter @trailin/server start",
    "typecheck": "pnpm -r typecheck"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.18.3"
}
