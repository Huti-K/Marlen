# --- LLM provider (pi-ai reads these directly) ---
ANTHROPIC_API_KEY=sk-ant-...

# Which model the agent uses (any provider/model pi-ai supports)
AGENT_PROVIDER=anthropic
AGENT_MODEL=claude-opus-4-8

# --- Pipedream Connect (project credentials from https://pipedream.com/projects -> your project -> Connect) ---
PIPEDREAM_CLIENT_ID=
PIPEDREAM_CLIENT_SECRET=
PIPEDREAM_PROJECT_ID=proj_...
PIPEDREAM_ENVIRONMENT=development

# Stable id for "you" inside Pipedream Connect. Any string; keep it constant.
PIPEDREAM_EXTERNAL_USER_ID=local-user

# --- Server ---
PORT=3001
# Path of the SQLite database file (created on first boot)
DATABASE_PATH=./data/trailin.db
